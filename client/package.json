{
  "name": "sonicrelay-client",
  "version": "0.1.52",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "electron:dev": "concurrently \"react-router dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:compile": "tsc -p electron/tsconfig.json && node -e \"const fs=require('fs'),p=require('path'),d='dist-electron';fs.readdirSync(d).filter(f=>f.endsWith('.js')).forEach(f=>fs.renameSync(p.join(d,f),p.join(d,f.replace('.js','.cjs'))))\"",
    "electron:build": "cross-env ELECTRON=true react-router build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@react-router/node": "7.13.1",
    "@react-router/serve": "7.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "isbot": "^5.1.36",
    "lucide-react": "^0.577.0",
    "mediasoup-client": "^3.18.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-router": "7.13.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^8.0.3"
  }
}
